        </div>
        <table>
          <thead>
            <tr>
              <th></th><th>JAN</th><th>FEV</th><th>MAR</th><th class="col-bpo">Almaviva</th><th class="col-bpo">tel.</th><th>ABR-26</th><th>ABR|MAR</th><th>ABR×MAR</th><th>Dispersão</th>
            </tr>
          </thead>
          <tbody>
            <tr class="row-q1">
              <td>Q1</td><td>533</td><td>455</td><td>232</td><td class="col-bpo">373</td><td class="col-bpo">467</td><td>437</td><td>334</td><td class="val-up-green">+88,00%</td><td>↑ 0,0%</td>
            </tr>
            <tr class="row-q2">
              <td>Q2</td><td>566</td><td>628</td><td>435</td><td class="col-bpo">428</td><td class="col-bpo">527</td><td>475</td><td>455</td><td class="val-up-green">+9,16%</td><td>↗ 36,0%</td>
            </tr>
            <tr class="row-q3">
              <td>Q3</td><td>682</td><td>743</td><td>549</td><td class="col-bpo">483</td><td class="col-bpo">611</td><td>578</td><td>564</td><td class="val-up-green">+5,27%</td><td>↗ 68,6%</td>
            </tr>
            <tr class="row-q4">
              <td>Q4</td><td>798</td><td>858</td><td>724</td><td class="col-bpo">652</td><td class="col-bpo">750</td><td>717</td><td>721</td><td class="val-down-blue">-1,02%</td><td>↓ 115,5%</td>
            </tr>
            <tr class="row-total">
              <td>Total</td><td>652</td><td>690</td><td>530</td><td class="col-bpo">446</td><td class="col-bpo">557</td><td>514</td><td>522</td><td class="val-down-blue">-3,02%</td><td>↗ 56,1%</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- TABELA CHAT -->
      <div class="tbl-container">
        <div class="tbl-header">
          <h3>AGIREVERTE (CHAT)</h3>
          <div style="display: flex; gap: 6px;">
            <span class="badge-ch b-chat">CHAT</span>
            <span class="badge-ch b-sys">Genesys</span>
          </div>
        </div>
        <table>
          <thead>
            <tr>
              <th></th><th>JAN</th><th>FEV</th><th>MAR</th><th class="col-bpo">Almaviva</th><th class="col-bpo">tel.</th><th>ABR-26</th><th>ABR|MAR</th><th>ABR×MAR</th><th>Dispersão</th>
            </tr>
          </thead>
          <tbody>
            <tr class="row-q1">
              <td>Q1</td><td>967</td><td>1.100</td><td>1.029</td><td class="col-bpo">791</td><td class="col-bpo">880</td><td>868</td><td>948</td><td class="val-down-blue">-15,70%</td><td>↑ 0,0%</td>
            </tr>
            <tr class="row-q2">
              <td>Q2</td><td>1.282</td><td>1.345</td><td>1.257</td><td class="col-bpo">1.150</td><td class="col-bpo">1.132</td><td>1.140</td><td>1.198</td><td class="val-down-blue">-9,32%</td><td>↗ 26,3%</td>
            </tr>
            <tr class="row-q3">
              <td>Q3</td><td>1.538</td><td>1.573</td><td>1.524</td><td class="col-bpo">1.236</td><td class="col-bpo">1.423</td><td>1.373</td><td>1.448</td><td class="val-down-blue">-9,95%</td><td>↗ 52,7%</td>
            </tr>
            <tr class="row-q4">
              <td>Q4</td><td>1.930</td><td>2.077</td><td>1.816</td><td class="col-bpo">1.514</td><td class="col-bpo">1.837</td><td>1.609</td><td>1.712</td><td class="val-down-blue">-11,36%</td><td>↓ 80,6%</td>
            </tr>
            <tr class="row-total">
              <td>Total</td><td>1.333</td><td>1.418</td><td>1.247</td><td class="col-bpo">1.120</td><td class="col-bpo">1.088</td><td>1.097</td><td>1.172</td><td class="val-down-blue">-12,00%</td><td>↗ 23,6%</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- GRÁFICOS INFERIORES -->
      <div class="charts-row">
        <div class="chart-box">
          <div class="chart-title">Evolução TMO Consolidado (Segundos)</div>
          <div class="canvas-wrapper"><canvas id="trendChart"></canvas></div>
        </div>
        <div class="chart-box">
          <div class="chart-title">Eficiência BPO: Almaviva vs Tel (Abr/26)</div>
          <div class="canvas-wrapper"><canvas id="bpoChart"></canvas></div>
