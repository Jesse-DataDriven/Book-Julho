    <span class="footer-center">Atendimento ao Cliente · Dispersão de TMA AgiReverte · Junho 2026</span>
    <span class="slide-counter">13 / 36</span>
  </div>

</div>

<script>
  function resizeSlide() {
    const wrapper = document.getElementById('scale-wrapper');
    const scale = Math.min(window.innerWidth / 1280, window.innerHeight / 720);
    wrapper.style.transform = `scale(${scale})`;
  }
  window.addEventListener('resize', resizeSlide);
  resizeSlide();

  Chart.register(ChartDataLabels);
  Chart.defaults.font.family = "'Inter', sans-serif";

  // 1. Gráfico de Evolução (Linha)
  const ctxTrend = document.getElementById('trendChart').getContext('2d');
  new Chart(ctxTrend, {
      type: 'line',
      data: {
          labels: ['Jan', 'Fev', 'Mar', 'Abr'],
          datasets: [
              {
                  label: 'Chat',
                  data: [1333, 1418, 1247, 1097],
                  borderColor: '#1a56db', backgroundColor: '#1a56db',
                  borderWidth: 2, tension: 0.3, pointRadius: 3,
                  datalabels: { display: true, align: 'top', offset: 4, color: '#1a56db', font: { weight: 'bold', size: 9 } }
              },
              {
                  label: 'Voz',
                  data: [652, 690, 530, 514],
                  borderColor: '#16a34a', backgroundColor: '#16a34a',
                  borderWidth: 2, tension: 0.3, pointRadius: 3,
                  datalabels: { display: true, align: 'bottom', offset: 4, color: '#16a34a', font: { weight: 'bold', size: 9 } }
              }
          ]
      },
      options: {
          responsive: true, maintainAspectRatio: false, devicePixelRatio: Math.max(window.devicePixelRatio || 1, 2),
          layout: { padding: { top: 15, bottom: 10, right: 15 } },
          plugins: { legend: { display: false }, tooltip: { enabled: false } },
          scales: {
              x: { grid: { display: false }, ticks: { font: { size: 9, weight: 'bold' }, color: '#6b7280' } },
              y: { display: false, min: 300, suggestedMax: 1600 }
          }
      }
  });

  // 2. Gráfico BPO (Barras)
  const ctxBpo = document.getElementById('bpoChart').getContext('2d');
  new Chart(ctxBpo, {
      type: 'bar',
      data: {
          labels: ['Almaviva', 'Tel'],
          datasets: [
              {
                  label: 'Chat',
                  data: [1120, 1088],
                  backgroundColor: '#1a56db',
                  borderRadius: 4, barPercentage: 0.6, categoryPercentage: 0.8,
                  datalabels: { display: true, align: 'top', anchor: 'end', offset: 2, color: '#1a56db', font: { weight: 'bold', size: 9 } }
              },
              {
                  label: 'Voz',
                  data: [446, 557],
                  backgroundColor: '#16a34a',
                  borderRadius: 4, barPercentage: 0.6, categoryPercentage: 0.8,
                  datalabels: { display: true, align: 'top', anchor: 'end', offset: 2, color: '#16a34a', font: { weight: 'bold', size: 9 } }
              }
          ]
      },
      options: {
          responsive: true, maintainAspectRatio: false, devicePixelRatio: Math.max(window.devicePixelRatio || 1, 2),
          layout: { padding: { top: 15 } },
          plugins: { legend: { display: false }, tooltip: { enabled: false } },
          scales: {
              x: { grid: { display: false }, ticks: { font: { size: 10, weight: 'bold' }, color: '#1f2937' } },
              y: { display: false, min: 0, suggestedMax: 1300 }
          }
      }
  });
</script>
</body>
</html>
