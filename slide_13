      <!-- TABELA VOZ -->
      <div class="tbl-container">
        <div class="tbl-header">
          <h3>AGIREVERTE (FONADO)</h3>
          <div style="display: flex; gap: 6px;">
            <span class="badge-ch b-voz">VOZ</span>
